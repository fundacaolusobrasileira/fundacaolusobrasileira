# RLS test environment — copy to .env.test and fill in credentials for a dedicated Supabase test project.
# NEVER use the production project here. Create a separate Supabase project exclusively for tests.
# Obtain these values in: Supabase Dashboard > Settings > API

SUPABASE_TEST_URL=https://<test-projeto>.supabase.co
SUPABASE_TEST_ANON_KEY=<anon-key-do-projeto-de-teste>
SUPABASE_TEST_SERVICE_ROLE_KEY=<service-role-key-do-projeto-de-teste>
